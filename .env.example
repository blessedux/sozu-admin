# Sozu Network Admin — admin.sozu.capital
# Copy to .env.local and fill in values.

NEXT_PUBLIC_APP_URL=http://localhost:3001

# Comma-separated emails allowed to sign in (SozuCapital team only)
SOZU_ADMIN_EMAILS=you@sozu.capital,ops@sozu.capital

# Session signing (required in production)
AUTH_SECRET=

# Cookie name (optional; default sozu_admin_session)
# SESSION_COOKIE_NAME=sozu_admin_session

# Skip login in local dev — grants admin session without email check
# AUTH_MOCK=true

# Supabase — shared network database (same project as wallet + pay)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Stellar
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
# USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
NEXT_PUBLIC_STELLAR_EXPLORER=https://stellar.expert/explorer/testnet

# SozuPay merchant dashboard (link from off-ramp queue for merchant USDC release)
# NEXT_PUBLIC_SOZUPAY_URL=http://localhost:3000

# Off-ramp USDC destination is configured in SozuPay (SOZU_OFF_RAMP_TREASURY_ADDRESS).
# Supports classic G or Soroban smart account C, e.g. CCNQCPFOV6SKAQVFGFXALAHJ3PUBT3EM63MJ4W3WRHKMNLV24R6T37UC

# Investor mode — optional shared secret for invest.sozu.capital embed
# INVESTOR_MODE_SECRET=
