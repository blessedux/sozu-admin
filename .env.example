# Sozu Network Admin — admin.sozu.capital
# Copy to .env.local and fill in values.

NEXT_PUBLIC_APP_URL=http://localhost:3001

# Comma-separated emails allowed to sign in (SozuCapital team only)
SOZU_ADMIN_EMAILS=you@sozu.capital,ops@sozu.capital

# Session signing (required in production)
AUTH_SECRET=

# Cookie name (optional; default sozu_admin_session)
# SESSION_COOKIE_NAME=sozu_admin_session

# Skip login in local dev — grants admin session without email check
# AUTH_MOCK=true

# Supabase — shared network database (same project as wallet + pay)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Stellar
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_STELLAR_EXPLORER=https://stellar.expert/explorer/testnet

# Investor mode — optional shared secret for invest.sozu.capital embed
# INVESTOR_MODE_SECRET=
